FROM node:20-slim AS base
RUN corepack enable && corepack prepare pnpm@8.15.4 --activate
WORKDIR /app

# Install dependencies
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/db/package.json packages/db/
COPY packages/pipeline/package.json packages/pipeline/
COPY packages/llm/package.json packages/llm/
COPY packages/plugins/package.json packages/plugins/
COPY packages/ui/package.json packages/ui/
COPY apps/web/package.json apps/web/
RUN pnpm install --frozen-lockfile || pnpm install --no-frozen-lockfile

# Copy source and build
COPY . .
RUN pnpm --filter @audit/db db:generate \
    && pnpm --filter @audit/db build \
    && pnpm --filter @audit/pipeline build \
    && pnpm --filter @audit/llm build \
    && pnpm --filter @audit/plugins build \
    && pnpm --filter @audit/ui build \
    && pnpm --filter @audit/web build

EXPOSE 5001
CMD ["pnpm", "--filter", "@audit/web", "start"]

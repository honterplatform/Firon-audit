# ============================================
# Railway: Postgres and Redis are auto-provided
# when you add them as add-ons. No need to set
# DATABASE_URL or REDIS_URL manually on Railway.
# ============================================

# Database (auto-set by Railway Postgres add-on)
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/audit_db

# Redis (auto-set by Railway Redis add-on)
REDIS_URL=redis://localhost:6379

# OpenAI API key (required — for AI summaries)
OPENAI_API_KEY=sk-your-openai-key-here

# Storage provider: "local", "supabase", or "s3"
STORAGE_PROVIDER=local

# Local storage directory (used when STORAGE_PROVIDER=local)
LOCAL_STORAGE_DIR=./data/uploads

# Supabase (if STORAGE_PROVIDER=supabase)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-key
# SUPABASE_BUCKET=audits

# S3 (if STORAGE_PROVIDER=s3)
# S3_BUCKET=audits
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key

# App config (set APP_BASE_URL to your Railway web service URL after first deploy)
APP_BASE_URL=http://localhost:5001
AUTH_SECRET=change-this-to-a-random-string
NEXTAUTH_URL=http://localhost:5001
